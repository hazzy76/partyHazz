{
  "manifest_version": 3,
  "name": "PartyHazz",
  "version": "1.0.0",
  "description": "Party para el Crunchyroll (Por ahora xD)",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "background": {
    "service_worker": "background/sw.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.crunchyroll.com/*/watch/*"
      ],
      "js": [
        "content/modulos/detectorVideo.js",
        "content/modulos/controladorVideo.js",
        "content/modulos/manejadorSync.js",
        "content/modulos/overlayUI.js",
        "content/crunchyroll.js"
      ],
      "css": [
        "content/content.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "permissions": [
    "storage",
    "tabs"
  ],
  "web_accessible_resources": [
    {
      "resources": ["content/modulos/reactHack.js"],
      "matches": ["*://*.crunchyroll.com/*"]
    }
  ],
  "host_permissions": [
    "*://*.crunchyroll.com/*",
    "ws://*/*",
    "wss://*/*"
  ]
}